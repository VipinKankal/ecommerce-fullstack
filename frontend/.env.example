# Copy the value you need into `.env.local`, `.env.development.local`, or
# deployment environment variables. A single frontend build uses one API origin
# at a time, and that origin may be either HTTP or HTTPS.

# Local development example
REACT_APP_API_BASE_URL=http://localhost:8080

# Deployed HTTPS example
# REACT_APP_API_BASE_URL=https://api.your-domain.com
