            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vipin\",\n  \"mobileNumber\": \"9123456789\",\n  \"address\": \"Street 1\",\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"pinCode\": \"411001\"\n}"
