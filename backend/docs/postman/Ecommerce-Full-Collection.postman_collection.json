{
  "info": {
    "name": "Ecommerce Master API Collection",
    "_postman_id": "0b7a6e61-7c0f-44c2-b0f6-80ba8131b1a1",
    "description": "Master collection generated from controller mappings in com.example.ecommerce.controller",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "customerEmail", "value": "testuser@gmail.com" },
    { "key": "sellerEmail", "value": "testseller@gmail.com" },
    { "key": "adminEmail", "value": "admin@gmail.com" },
    { "key": "otp", "value": "" },
    { "key": "customerJwt", "value": "" },
    { "key": "sellerJwt", "value": "" },
    { "key": "adminJwt", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "orderItemId", "value": "1" },
    { "key": "cartItemId", "value": "1" },
    { "key": "reviewId", "value": "1" },
    { "key": "couponId", "value": "1" },
    { "key": "sellerId", "value": "1" },
    { "key": "paymentId", "value": "pay_123" },
    { "key": "paymentLinkId", "value": "plink_123" }
