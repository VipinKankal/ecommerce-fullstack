        {
          "name": "Update Review",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerJwt}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reviewText\": \"Updated review\",\n  \"reviewRating\": 4\n}" },
