          "name": "Add Product To Wishlist",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerJwt}}" }],
            "url": "{{baseUrl}}/api/wishlist/add-product/{{productId}}"
