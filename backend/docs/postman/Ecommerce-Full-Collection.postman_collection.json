  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Home",
          "request": { "method": "GET", "url": "{{baseUrl}}/" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"{{customerEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signup"
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"signing_{{customerEmail}}\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/sent/login-signup-otp"
          }
        },
        {
          "name": "Signin Customer OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signin"
          }
        },
        {
          "name": "Signin Seller OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller_{{sellerEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signin"
          }
        },
        {
          "name": "Signin Admin OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin_{{adminEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signin"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "User Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerJwt}}" }],
            "url": "{{baseUrl}}/api/users/profile"
          }
        },
        {
          "name": "User Profile (Auth Alias)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerJwt}}" }],
            "url": "{{baseUrl}}/api/auth/users/profile"
          }
        }
      ]
    },
    {
      "name": "Seller",
      "item": [
        {
          "name": "Seller Login (Legacy Endpoint)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"otp\": \"{{otp}}\"\n}" },
            "url": "{{baseUrl}}/sellers/login"
          }
        },
        {
          "name": "Verify Seller Email",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/sellers/verifyEmail/{{otp}}"
          }
        },
        {
          "name": "Create Seller",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sellerName\": \"Test Seller\",\n  \"mobileNumber\": \"9123456789\",\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"Seller@123\",\n  \"GSTIN\": \"27AAECA1234F1Z5\",\n  \"businessDetails\": {\n    \"businessName\": \"Test Business\",\n    \"businessEmail\": \"biz@test.com\",\n    \"businessMobile\": \"9123456789\",\n    \"businessAddress\": \"Mumbai\",\n    \"logo\": \"\",\n    \"banner\": \"\"\n  },\n  \"bankDetails\": {\n    \"accountHolderName\": \"Test Seller\",\n    \"accountNumber\": \"123456789012\",\n    \"ifscCode\": \"HDFC0001234\"\n  },\n  \"pickupAddress\": {\n    \"name\": \"Warehouse\",\n    \"mobileNumber\": \"9123456789\",\n    \"street\": \"MIDC\",\n    \"locality\": \"Andheri East\",\n    \"address\": \"Plot 10 MIDC\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"pinCode\": \"400093\"\n  }\n}"
            },
            "url": "{{baseUrl}}/sellers"
          }
        },
        {
          "name": "Seller Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerJwt}}" }],
            "url": "{{baseUrl}}/sellers/profile"
          }
        },
        {
          "name": "Get Seller By Id (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/sellers/{{sellerId}}"
          }
        },
        {
          "name": "Get All Sellers (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/sellers?status=PENDING_VERIFICATION"
          }
        },
        {
          "name": "Update Seller (Seller)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerJwt}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"sellerName\": \"Updated Seller\"\n}" },
            "url": "{{baseUrl}}/sellers"
          }
        },
        {
          "name": "Delete Seller (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/sellers/{{sellerId}}"
          }
        },
        {
          "name": "Update Seller Account Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/sellers/{{sellerId}}/status?status=APPROVED"
          }
        },
        {
          "name": "Seller Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerJwt}}" }],
            "url": "{{baseUrl}}/sellers/report"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/api/admin/profile"
          }
        },
        {
          "name": "Admin Profile (Alias)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Update Seller Status (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminJwt}}" }],
            "url": "{{baseUrl}}/api/admin/seller/{{sellerId}}/status/APPROVED"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get Product By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products/{{productId}}" }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products/search?query=phone" }
        },
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?pageNumber=0&sort=price_low" }
        }
      ]
    },
    {
      "name": "Seller Products",
      "item": [
        {
          "name": "Get Seller Products",
