          "name": "Create Seller Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerJwt}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Product\",\n  \"description\": \"Demo\",\n  \"category\": \"Electronics\",\n  \"category2\": \"Mobiles\",\n  \"category3\": \"Smartphones\",\n  \"mrpPrice\": 20000,\n  \"sellingPrice\": 15000,\n  \"quantity\": 10,\n  \"color\": \"Black\",\n  \"images\": [\"https://example.com/p1.png\"],\n  \"sizes\": [\"M\", \"L\"]\n}"
            },
            "url": "{{baseUrl}}/api/sellers/products"
          }
        },
        {
          "name": "Update Seller Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerJwt}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Product\",\n  \"description\": \"Updated\",\n  \"mrpPrice\": 22000,\n  \"sellingPrice\": 16000,\n  \"quantity\": 8\n}"
            },
            "url": "{{baseUrl}}/api/sellers/products/{{productId}}"
          }
        },
        {
          "name": "Delete Seller Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerJwt}}" }],
            "url": "{{baseUrl}}/api/sellers/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerJwt}}" }],
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Add Item To Cart",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerJwt}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}},\n  \"size\": \"M\",\n  \"quantity\": 1\n}" },
            "url": "{{baseUrl}}/api/cart/add"
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerJwt}}" }
