            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 2\n}" },
            "url": "{{baseUrl}}/api/cart/item/{{cartItemId}}"
          }
        },
        {
          "name": "Delete Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerJwt}}" }],
            "url": "{{baseUrl}}/api/cart/item/{{cartItemId}}"
