# Production environment template for Ecommerce backend
# Do not commit real secrets.

# App
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
GST_VERIFICATION_MODE=MANUAL
GST_VERIFICATION_ACTIVE_GSTINS=
GST_VERIFICATION_API_URL=
GST_VERIFICATION_API_KEY=

# Database
DB_URL=jdbc:mysql://<db-host>:3306/ecommerce?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=false
DB_USERNAME=<db_user>
DB_PASSWORD=<db_password>

# JWT
# Generate at least 64 random characters.
JWT_SECRET_KEY=<very-long-random-secret-64-plus-chars>
JWT_EXPIRATION_MS=86400000

# Mail (SMTP)
MAIL_USERNAME=<smtp_username>
MAIL_PASSWORD=<smtp_password_or_app_password>
APP_EMAIL_DEV_FALLBACK_ENABLED=false
APP_EMAIL_DEV_LOG_OTP=false

# Payment providers
RAZORPAY_API_KEY=<razorpay_key>
RAZORPAY_API_SECRET=<razorpay_secret>
STRIPE_SECRET_KEY=<stripe_secret>

# Optional tuning
JPA_SHOW_SQL=false
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
SWAGGER_ENABLED=false
FLYWAY_ENABLED=true
